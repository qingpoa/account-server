ACCOUNT_AGENT_API_KEY=your_dashscope_api_key
ACCOUNT_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ACCOUNT_AGENT_MODEL=qwen3.5-flash
ACCOUNT_AGENT_VISION_MODEL=qwen3.5-flash
ACCOUNT_AGENT_TEMPERATURE=0
ACCOUNT_AGENT_THREAD_ID=demo-thread
ACCOUNT_AGENT_LEDGER_PATH=./data/ledger.json

# Optional: only set these if you want the vision model to use a different provider or key.
# ACCOUNT_AGENT_VISION_API_KEY=your_vision_api_key
# ACCOUNT_AGENT_VISION_BASE_URL=https://your-openai-compatible-endpoint

# Backward-compatible legacy variables are still supported:
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsxxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGCHAIN_PROJECT=accounting-agent
